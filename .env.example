# 책잇다 환경변수 예시 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   Windows: copy .env.example .env   /   mac·Linux: cp .env.example .env
# .env 는 git에 올라가지 않습니다(.gitignore). 키는 각자 발급하거나 팀 안전채널로만 공유.

# ── Django ───────────────────────────────────────────────
# 필수. 생성: python -c "import secrets;print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# ── 정보나루(도서관 API) ─────────────────────────────────
# 권장. 책 상세 지도/가용성 실시간 조회(bookExist·libSrchByBook·usageAnalysisList).
# 없으면 지도가 '상태 미확인'으로 폴백(앱은 동작). 가입→마이페이지→인증키(승인 ~하루).
LIBRARY_API_KEY=

# ── SSAFY GMS (LLM 추천 · 임베딩) ────────────────────────
# 권장. 없으면 추천이 인기순 폴백으로 동작.
GMS_KEY=
GMS_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_MODEL=gpt-5-nano

# ── 데이터 수집 스크립트용 (앱 실행엔 불필요) ────────────
# scripts/collect_aladin.py·enrich_books.py 등 카탈로그·메타 수집할 때만 필요.
ALADIN_TTB_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
