# .env.example — .env 로 복사해서 값을 채운다. (.env 는 .gitignore)

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# 정보나루 (도서관 가용성)
LIBRARY_API_KEY=

# SSAFY GMS (추천)
GMS_KEY=
GMS_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_MODEL=gpt-5-nano

# 데이터 수집 스크립트용 (앱 실행엔 불필요)
ALADIN_TTB_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
